        <mxCell id="legend" value="Категории: &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Инфраструктура, ПО, Интеграция&lt;br&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Данные, Персонал, Безопасность, Процессы&amp;nbsp;" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#666666" parent="1" vertex="1">
